<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>IntelliOps AI</title>

    <!-- Bootstrap -->
    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Site CSS -->
    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

</head>

<body>

    <div class="d-flex">

        <!-- SIDEBAR -->
        <div class="sidebar">

            <div>

                <h2 style="color:white; font-weight:800; margin-bottom:5px;">
                    IntelliOps AI
                </h2>

                <p style="color:#e2e8f0; margin-bottom:30px;">
                    Workforce Intelligence
                </p>

                <a href="/Home/Index" class="sidebar-link">
                    <i class="bi bi-grid-fill"></i>
                    Dashboard
                </a>

                <a href="/WorkLog/Index" class="sidebar-link">
                    <i class="bi bi-clipboard-data-fill"></i>
                    Work Logs
                </a>

                <a href="/AIReport/Index" class="sidebar-link">
                    <i class="bi bi-robot"></i>
                    AI Reports
                </a>

                <a href="/Import/Index" class="sidebar-link">
                    <i class="bi bi-upload"></i>
                    Import Data
                </a>

            </div>

            <div>

                <a href="/Account/Login" class="sidebar-link logout-link">
                    <i class="bi bi-box-arrow-right"></i>
                    Logout
                </a>

            </div>

        </div>

        <!-- MAIN CONTENT -->
        <div class="content">

            <div class="container-fluid mt-4">

                @RenderBody()

            </div>

        </div>

    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>