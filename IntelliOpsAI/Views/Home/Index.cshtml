@{
    ViewData["Title"] = "Dashboard";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h2>IntelliOps AI Dashboard</h2>

            <p class="text-muted">
                Real-time workforce analytics and operational intelligence
            </p>

        </div>

        <a href="/WorkLog/Create"
           class="btn btn-primary">

            + Add Work Log

        </a>

    </div>

    <!-- KPI CARDS -->
    <div class="row mb-4">

        <div class="col-md-3">

            <div class="card p-4 text-white bg-primary">

                <h6>Total Logs</h6>

                <h2>@ViewBag.TotalLogs</h2>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card p-4 text-white bg-success">

                <h6>Completed Tasks</h6>

                <h2>@ViewBag.CompletedTasks</h2>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card p-4 text-white bg-warning">

                <h6>Pending Tasks</h6>

                <h2>@ViewBag.PendingTasks</h2>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card p-4 text-white bg-dark">

                <h6>Total Hours</h6>

                <h2>@ViewBag.TotalHours</h2>

            </div>

        </div>

    </div>

    <!-- CHARTS -->
    <div class="row mb-4">

        <!-- PIE CHART -->
        <div class="col-md-6">

            <div class="card p-4">

                <h5 class="mb-3">
                    Task Distribution
                </h5>

                <div style="max-width:350px; margin:auto;">

                    <canvas id="taskChart"></canvas>

                </div>

            </div>

        </div>

        <!-- BAR CHART -->
        <div class="col-md-6">

            <div class="card p-4">

                <h5 class="mb-3">
                    Productivity Overview
                </h5>

                <canvas id="hoursChart"></canvas>

            </div>

        </div>

    </div>

    <!-- AI INSIGHT -->
    <div class="card p-4">

        <h4 class="mb-3">
            AI Operational Insight
        </h4>

        <p class="text-muted">

            @ViewBag.AIInsight

        </p>

    </div>

</div>

<script>

    // TASK DISTRIBUTION CHART
    new Chart(document.getElementById('taskChart'), {

        type: 'doughnut',

        data: {

            labels: ['Completed', 'Pending', 'In Progress'],

            datasets: [{
                data: [
    @ViewBag.CompletedTasks,
    @ViewBag.PendingTasks,
    @ViewBag.InProgressTasks
                    ]
            }]
        },

        options: {
            responsive: true,
            maintainAspectRatio: true
        }

    });

    // PRODUCTIVITY CHART
    new Chart(document.getElementById('hoursChart'), {

        type: 'bar',

        data: {

            labels: ['Total Hours Worked'],

            datasets: [{
                label: 'Hours',
                data: [@ViewBag.TotalHours]
            }]
        },

        options: {
            responsive: true
        }

    });

</script>