@model IntelliOpsAI.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid p-4">

    <div class="mb-4">
        <h2 style="font-weight:700;">Enterprise Analytics Dashboard</h2>
        <p style="color:gray;">
            AI-powered workforce intelligence and system analytics
        </p>
    </div>

    <!-- KPI CARDS -->

    <div class="row mb-4">

        <div class="col-md-3">
            <div class="card shadow-sm border-0 p-3">
                <h6>Total Logs</h6>
                <h2>@Model.TotalLogs</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 p-3">
                <h6>Total Hours</h6>
                <h2>@Model.TotalHours</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 p-3">
                <h6>Completed Tasks</h6>
                <h2>@Model.Completed</h2>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 p-3">
                <h6>Pending Tasks</h6>
                <h2>@Model.Pending</h2>
            </div>
        </div>

    </div>

    <!-- AI INSIGHT -->

    <div class="alert alert-info shadow-sm">
        <strong>AI Insight:</strong> @Model.AIInsight
    </div>

    <!-- CHART -->

    <div class="card shadow-sm border-0 p-4 mt-4">

        <h5 class="mb-4">System Distribution</h5>

        <div style="height:400px;">
            <canvas id="systemChart"></canvas>
        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script>

    window.onload = function () {

        const labels = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(Model.SystemLabels)
            );

        const values = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(Model.SystemValues)
            );

        const ctx = document
            .getElementById("systemChart")
            .getContext("2d");

        new Chart(ctx, {
            type: 'doughnut',

            data: {
                labels: labels,

                datasets: [{
                    label: 'System Usage',
                    data: values,

                    backgroundColor: [
                        '#4e79a7',
                        '#f28e2b',
                        '#e15759'
                    ],

                    borderWidth: 1
                }]
            },

            options: {
                responsive: true,
                maintainAspectRatio: false
            }
        });

    };

</script>