@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>IntelliOps AI Dashboard</h2>

        <a href="/WorkLog" class="btn btn-dark">
            Go to Work Logs
        </a>
    </div>

    <div class="row">

        <div class="col-md-4">
            <div class="card shadow p-3 mb-3">
                <h5>Total Employees</h5>
                <h2>24</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow p-3 mb-3">
                <h5>Active Tasks</h5>
                <h2>58</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow p-3 mb-3">
                <h5>Pending Reviews</h5>
                <h2>12</h2>
            </div>
        </div>

    </div>

    <div class="card mt-4 shadow p-3">

        <h5>AI Insight</h5>

        <p>
            Productivity is stable. Peak efficiency observed during morning hours.
            Suggested improvement: redistribute workload evenly across teams.
        </p>

    </div>

</div>