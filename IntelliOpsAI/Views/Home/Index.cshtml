@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2>IntelliOps AI Dashboard</h2>
            <p class="text-muted">
                Enterprise workforce intelligence and analytics system
            </p>
        </div>

        <a href="/WorkLog/Create" class="btn btn-primary">
            + Add Work Log
        </a>

    </div>

    <!-- KPI CARDS -->
    <div class="row mb-4">

        <div class="col-md-3">

            <div class="card p-4 text-white bg-primary">

                <h6>Total Employees</h6>
                <h2>24</h2>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card p-4 text-white bg-success">

                <h6>Completed Tasks</h6>
                <h2>58</h2>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card p-4 text-white bg-warning">

                <h6>Pending Reviews</h6>
                <h2>12</h2>

            </div>

        </div>

        <div class="col-md-3">

            <div class="card p-4 text-white bg-danger">

                <h6>Alerts</h6>
                <h2>4</h2>

            </div>

        </div>

    </div>

    <!-- CHARTS -->
    <div class="row">

        <div class="col-md-8 mb-4">

            <div class="card p-4">

                <h5 class="mb-3">Employee Productivity</h5>

                <canvas id="productivityChart"></canvas>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card p-4">

                <h5 class="mb-3">Task Distribution</h5>

                <canvas id="taskChart"></canvas>

            </div>

        </div>

    </div>

    <!-- LOWER SECTION -->
    <div class="row">

        <!-- RECENT ACTIVITY -->
        <div class="col-md-6 mb-4">

            <div class="card p-4">

                <h5 class="mb-3">Recent Activity</h5>

                <ul class="list-group">

                    <li class="list-group-item">
                        Rahul completed Inventory Module
                    </li>

                    <li class="list-group-item">
                        Priya submitted AI Report
                    </li>

                    <li class="list-group-item">
                        Sneha updated supplier workflow
                    </li>

                    <li class="list-group-item">
                        Karan resolved pending review
                    </li>

                </ul>

            </div>

        </div>

        <!-- AI INSIGHT -->
        <div class="col-md-6 mb-4">

            <div class="card p-4">

                <h5 class="mb-3">AI Insight Engine</h5>

                <p class="text-muted">
                    AI analysis detected stable operational efficiency with improved task completion trends.
                    Recommendation: optimize workload balancing to increase throughput and reduce pending reviews.
                </p>

            </div>

        </div>

    </div>

</div>

<!-- CHART JS CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    // BAR CHART
    const productivityCtx = document.getElementById('productivityChart');

    new Chart(productivityCtx, {
        type: 'bar',
        data: {
            labels: ['Rahul', 'Aman', 'Priya', 'Sneha', 'Karan'],
            datasets: [{
                label: 'Hours Worked',
                data: [7, 8, 6, 9, 5],
                borderWidth: 1
            }]
        },
        options: {
            responsive: true
        }
    });

    // PIE CHART
    const taskCtx = document.getElementById('taskChart');

    new Chart(taskCtx, {
        type: 'pie',
        data: {
            labels: ['Completed', 'Pending', 'In Progress'],
            datasets: [{
                data: [18, 7, 12]
            }]
        },
        options: {
            responsive: true
        }
    });

</script>