@{
    ViewData["Title"] = "Dashboard";
}

<div class="container">

    <div class="mb-4">
        <h2>IntelliOps AI Dashboard</h2>
        <p class="text-muted">Operational intelligence & workforce analytics</p>
    </div>

    <div class="row">

        <div class="col-md-4">
            <div class="card text-center p-4">
                <h5>Total Employees</h5>
                <h2>24</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center p-4">
                <h5>Active Tasks</h5>
                <h2>58</h2>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center p-4">
                <h5>Pending Reviews</h5>
                <h2>12</h2>
            </div>
        </div>

    </div>

    <div class="card mt-4 p-4">

        <h5>AI Insight Engine</h5>

        <p class="text-muted">
            System analysis indicates stable productivity patterns with peak efficiency during morning hours.
            Recommended action: optimize workload distribution across teams for improved throughput.
        </p>

    </div>

</div>