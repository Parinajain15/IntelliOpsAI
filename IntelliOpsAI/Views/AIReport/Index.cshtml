@{
    ViewData["Title"] = "AI Reports";
}

<div class="container mt-4">

    <h2>AI Reports Module</h2>

    <p>
        Generate intelligent productivity insights based on system work logs.
    </p>

    <a href="/AIReport/Generate" class="btn btn-dark mb-3">
        Generate AI Report
    </a>

    @if (ViewBag.Report != null)
    {
        <div class="card shadow p-3 mt-3">

            <h5>Generated Report</h5>

            <pre style="white-space: pre-wrap;">@ViewBag.Report</pre>

        </div>
    }

</div>