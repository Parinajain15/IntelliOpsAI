@{
    ViewData["Title"] = "AI Reports";
}

<div class="container mt-4">

    <h2>AI Reports Engine</h2>
    <p class="text-muted">Generate AI-style workforce analysis reports</p>

    <a href="/AIReport/Generate" class="btn btn-dark mb-3">
        Generate Report
    </a>

    @if (ViewBag.Report != null)
    {
        <div class="card p-4 mt-3">

            <h5>Generated AI Report</h5>

            <pre style="white-space: pre-wrap; font-size: 14px;">
                @ViewBag.Report
                </pre>

        </div>
    }

</div>