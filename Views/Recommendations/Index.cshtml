@using System.Reflection
@model IEnumerable<IntelliOps.Models.Recommendation>
@{
    ViewData["Title"] = "Autonomous Optimizer Queue";
}

@functions {
    public string GetPropValue(object obj, string[] propNames, string fallback = "")
    {
        if (obj == null) return fallback;
        var type = obj.GetType();
        foreach (var name in propNames)
        {
            var prop = type.GetProperty(name);
            if (prop != null)
            {
                var val = prop.GetValue(obj);
                if (val != null && !string.IsNullOrWhiteSpace(val.ToString())) return val.ToString();
            }
        }
        return fallback;
    }
}

<div class="space-y-8">
    
    <!-- Header panel description -->
    <div class="bento-card p-6">
        <h3 class="font-bold text-gray-900 text-sm">Autonomous Operational Mitigations Queue</h3>
        <p class="text-xs text-gray-500 mt-1 leading-relaxed max-w-4xl">
            Review recommendations computed by IntelliOps optimizer routines based on workload imbalances, queue breaches, and active department logs. 
            Mitigation execution shifts staff capacity, updates SAP states, and resolves active SLA alerts inside the database.
        </p>
    </div>

    <!-- Recommendations bento-grid logs -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        @if (Model != null && Model.Any())
        {
            foreach (var rec in Model)
            {
                var id = GetPropValue(rec, new[] { "Id" }, "");
                var title = GetPropValue(rec, new[] { "Title", "MitigationPlan", "Name" }, "Operational Recommendation");
                var severity = GetPropValue(rec, new[] { "Severity", "Impact", "Priority" }, "High");
                var department = GetPropValue(rec, new[] { "Department", "DepartmentName" }, "Operations");
                var action = GetPropValue(rec, new[] { "ActionablePlan", "Action", "RecommendedAction", "Description" }, "No remediation steps available.");
                var reason = GetPropValue(rec, new[] { "MetricReference", "Reason", "RootCause", "TriggerReason" }, "Calculated dynamic risk signal.");
                var status = GetPropValue(rec, new[] { "Status" }, "Open");

                <div class="bento-card p-6 flex flex-col justify-between">
                    
                    <div>
                        <!-- Header banner -->
                        <div class="flex items-center justify-between mb-4 pb-2 border-b border-gray-100">
                            <span class="px-2 py-0.5 rounded text-[10px] font-bold uppercase border
                                @(severity == "Critical" || severity == "High" ? "bg-red-50 text-red-700 border-red-100" :
                                  severity == "Medium" || severity == "Moderate" ? "bg-amber-50 text-amber-800 border-amber-200" :
                                  "bg-emerald-50 text-emerald-700 border-emerald-100")">
                                @severity Impact
                            </span>
                            <span class="text-[10px] bg-slate-55 text-slate-500 font-bold uppercase border border-slate-200 px-2.5 py-0.5 rounded">
                                Queue: @department
                            </span>
                        </div>

                        <!-- Recommendations details -->
                        <h4 class="font-bold text-gray-950 text-xs mb-1">@title</h4>
                        <span class="text-[10px] text-gray-400 block mb-4">Calculated trigger issue: @reason</span>

                        <p class="text-xs text-slate-600 leading-relaxed mb-4">
                            @action
                        </p>
                    </div>

                    <!-- Actions button to execute mitigation plan -->
                    <div class="border-t border-gray-100 pt-4 flex items-center justify-between mt-4">
                        <div class="text-[11px] font-medium text-slate-500">
                            Status State: 
                            <span class="font-bold uppercase tracking-tight
                                @(status == "Active" || status == "Open" ? "text-amber-600 animate-pulse" : "text-emerald-600")">
                                @status
                            </span>
                        </div>

                        @if (status == "Active" || status == "Open")
                        {
                            <form action="/Recommendations/Execute" method="post">
                                <input type="hidden" name="id" value="@id" />
                                <input type="hidden" name="department" value="@department" />
                                <input type="hidden" name="title" value="@title" />
                                <button type="submit" class="btn btn-success text-xs px-3 py-1.5">
                                    Execute Mitigation Plan
                                </button>
                            </form>
                        }
                        else
                        {
                            <button type="button" disabled class="btn btn-secondary text-xs px-3 py-1.5 opacity-60 select-none cursor-not-allowed">
                                Mitigation Executed
                            </button>
                        }
                    </div>

                </div>
            }
        }
        else
        {
            <div class="bento-card p-12 text-center text-slate-400 text-xs col-span-2">
                No active optimization recommendations inside data streams currently.
            </div>
        }
    </div>
</div>
